{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Furniture product details",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "rating": { "type": "number" },
        "stock": { "type": "number" },
        "features": { "type": "array" },
        "translations": { "type": "object" }
      },
      "required": ["name", "price", "category"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "translations": { "type": "object" }
      },
      "required": ["slug", "name"]
    },
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "wishlist": { "type": "array" },
        "cart": { "type": "array" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Purchase records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Review": {
      "title": "Review",
      "description": "Customer testimonials",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Furniture products collection"
    },
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Categorized furniture groups"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User accounts and preferences"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Product reviews"
    }
  }
}
